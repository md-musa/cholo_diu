{
  "expo": {
    "name": "Cholo",
    "slug": "cholo",
    "scheme": "cholo",
    "owner": "md_musa_dev",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/play_store_512.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch"],
        "NSLocationAlwaysUsageDescription": "We need your location even in the background.",
        "NSLocationWhenInUseUsageDescription": "We need your location while using the app.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "To share your live location even in background."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "versionCode": 1,
      "targetSdkVersion": 35,
      "compileSdkVersion": 35,

      "adaptiveIcon": {
        "foregroundImage": "./assets/images/play_store_512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.musa.cholo",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "foregroundService": {
        "notificationTitle": "Live Bus Tracking",
        "notificationBody": "Sharing your bus location in real-time."
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "cholo"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Cholo to access your location so you can see your position on the map and get accurate distances to active buses",
          "isBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "DVELOPMENT_SERVER_URL": "http://192.168.1.10:4000",
      "PRODUCTION_SERVER_URL": "https://choloserver-production.up.railway.app",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "11016b38-a11f-4cf4-bfb6-267111275cd7"
      },
      "androidMetadata": {
        "com.mapbox.token": "your_dummy_mapbox_token"
      }
    }
  }
}
