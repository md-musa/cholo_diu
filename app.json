{
  "expo": {
    "name": "Cholo",
    "slug": "cholo",
    "scheme": "cholo",
    "owner": "md_musa_dev",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/play_store_512.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/play_store_512.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.musa.cholo",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE_LOCATION"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "cholo"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-512.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@maplibre/maplibre-react-native",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Cholo to access your location so you can see your position on the map and get accurate distances to active buses",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "foregroundService": {
            "notificationTitle": "Cholo is tracking your location",
            "notificationBody": "Your location is being shared with the trip",
            "notificationColor": "#0066cc"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "DEV_SERVER_URL": "http://192.168.1.14:4000",
      "CLOUDFLARE_URL": "https://cholo.mohammad-musa-dev.workers.dev",

      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "11016b38-a11f-4cf4-bfb6-267111275cd7"
      },
      "androidMetadata": {
        "com.mapbox.token": "your_dummy_mapbox_token"
      }
    }
  }
}
